PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smarthome

# JWT
JWT_SECRET=change_me_super_secret
JWT_ISSUER=smarthomeee
JWT_AUDIENCE=smarthomeee

# MQTT (HiveMQ Cloud over TLS)
MQTT_URL=mqtts://YOUR-CLUSTER.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# InfluxDB (optional, enables /api/data/history + timeseries writes)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influx_token
INFLUX_ORG=smarthome
INFLUX_BUCKET=sensors

# ML Service (optional)
ML_SERVICE_URL=http://localhost:8000

